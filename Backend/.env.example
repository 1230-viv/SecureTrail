# SecureTrail Backend — Environment Variables Template
# Copy this file to .env and fill in real values. Never commit .env to git!

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
GITHUB_REDIRECT_URI=http://localhost:3000/oauth-callback.html

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ── JWT (internal signing) ────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_USE_A_64_CHAR_RANDOM_HEX
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Upload ────────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=104857600

# ── AWS Credentials ───────────────────────────────────────────────────────────
# Recommended: use IAM roles on EC2/ECS rather than static keys.
# If you must use static keys, generate a least-privilege IAM user.
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# ── AWS S3 Storage ────────────────────────────────────────────────────────────
S3_BUCKET_NAME=your-securetrail-bucket
S3_REGION=us-east-1

# ── AWS Bedrock (AI Security Mentor) ─────────────────────────────────────────
# Model: Meta Llama 4 Maverick via Bedrock us-east-1
# Ensure model access is enabled in the AWS Bedrock console.
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=meta.llama4-maverick-17b-instruct-v1:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.6
BEDROCK_CHAT_MAX_TOKENS=2048

# ── AI Toggle ─────────────────────────────────────────────────────────────────
AI_ENABLED=true
AI_SCORE_THRESHOLD=7.0
AI_MAX_CONCURRENT=3

# ── Scanner Tuning ────────────────────────────────────────────────────────────
SEMGREP_RULES=p/default
SEMGREP_DOCKER_MEM=512m
SEMGREP_DOCKER_CPU=1
SEMGREP_TIMEOUT=180
SEMGREP_IMAGE=returntocorp/semgrep:latest
GITLEAKS_DOCKER_MEM=256m
GITLEAKS_TIMEOUT=120
GITLEAKS_IMAGE=zricethezav/gitleaks:latest

# Trivy
TRIVY_TIMEOUT=180
TRIVY_DOCKER_MEM=512m
TRIVY_SEVERITY=UNKNOWN,LOW,MEDIUM,HIGH,CRITICAL
TRIVY_IMAGE=aquasec/trivy:latest

# ── Temp & paths ──────────────────────────────────────────────────────────────
TEMP_ROOT=/tmp/securetrail_jobs
GIT_CLONE_TIMEOUT=120

# ── PostgreSQL Database ───────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://securetrail:your_db_password@localhost:5432/securetrail
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_COMMAND_TIMEOUT=30
