# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_REDIRECT_URI=http://localhost:5173/auth/callback

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# ── JWT (internal signing) ────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_USE_A_LONG_RANDOM_VALUE
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── AWS Bedrock (AI Explanations) ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_MAX_TOKENS=2048
BEDROCK_TEMPERATURE=0.1

# ── AI Toggle ─────────────────────────────────────────────────────────────────
AI_ENABLED=true
AI_SCORE_THRESHOLD=7.0
AI_MAX_CONCURRENT=3

# ── Scanner Tuning ────────────────────────────────────────────────────────────
SEMGREP_RULES=p/default
SEMGREP_DOCKER_MEM=512m
SEMGREP_DOCKER_CPU=1
SEMGREP_TIMEOUT=180
SEMGREP_IMAGE=returntocorp/semgrep:latest
GITLEAKS_DOCKER_MEM=256m
GITLEAKS_TIMEOUT=120
GITLEAKS_IMAGE=zricethezav/gitleaks:latest

# Trivy (replaces npm audit — covers npm, pip, gem, go, maven, cargo, OS pkgs)
TRIVY_TIMEOUT=180
TRIVY_DOCKER_MEM=512m
TRIVY_SEVERITY=UNKNOWN,LOW,MEDIUM,HIGH,CRITICAL
TRIVY_IMAGE=aquasec/trivy:latest

# ── Upload ────────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE=104857600

# ── Temp Directory ────────────────────────────────────────────────────────────
TEMP_ROOT=/tmp/securetrail_jobs
GIT_CLONE_TIMEOUT=120
# ── PostgreSQL Database ───────────────────────────────────────────────────────
# asyncpg DSN (used by SQLAlchemy async engine)
DATABASE_URL=postgresql+asyncpg://securetrail:securetrail_db_pass@localhost:5432/securetrail
# Connection pool tuning (suitable for single EC2 instance)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_COMMAND_TIMEOUT=30
# Set to "true" only for local debugging (logs every SQL statement)
DB_ECHO=false